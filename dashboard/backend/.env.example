# Qdrant Cloud (gRPC, port 6334)
# Get your cluster URL and API key from https://cloud.qdrant.io
QDRANT_ADDR=your-cluster-id.region.gcp.cloud.qdrant.io:6334
QDRANT_API_KEY=your-api-key-here

# For a local Qdrant container instead, use:
# QDRANT_ADDR=localhost:6334
# QDRANT_API_KEY=

# Path to the downloaded ONNX model directory
MODEL_PATH=./models/all-MiniLM-L6-v2

# Use INT8-quantized model (faster); set to false to use FP32
EMBED_QUANTIZED=true

# Path to the alerts/ folder (relative to the binary)
ALERTS_ROOT=../../alerts

# Backend listen address
LISTEN_ADDR=:8080
